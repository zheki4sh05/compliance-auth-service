# Database credentials for PostgreSQL
POSTGRES_DB=auth_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spring DataSource configuration (used in application-docker.yaml)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/auth_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres


OAUTH2_KEY_ID=auth-service-rsa-key
# PKCS#8 private key (BEGIN PRIVATE KEY), one line with \n
OAUTH2_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY----------END PRIVATE KEY-----
# Optional. If omitted, service will try to derive public key from private key.
# X.509 public key (BEGIN PUBLIC KEY), one line with \n
OAUTH2_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY----------END PUBLIC KEY-----